{
  "name": "fieldtest",
  "private": true,
  "scripts": {
    "build": "pnpm --filter fieldtest build",
    "dev": "pnpm --filter fieldtest dev & pnpm --filter example dev",
    "test:node": "pnpm --filter example test:node",
    "test:node:watch": "pnpm --filter example test:node:watch",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:dev": "pnpm --filter e2e test:dev",
    "test:e2e:build": "pnpm --filter e2e test:build",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  }
}
