{
  "name": "fieldtest",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @fieldtest/core build",
    "dev": "pnpm --filter @fieldtest/core dev & pnpm --filter example dev",
    "test:node": "pnpm --filter example test:node",
    "test:node:watch": "pnpm --filter example test:node:watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  }
}
