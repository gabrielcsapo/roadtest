{
  "name": "@fieldtest/runner",
  "version": "0.0.0",
  "bin": {
    "fieldtest": "./bin/fieldtest.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    "./bin/fieldtest.js": "./bin/fieldtest.js",
    "./render": {
      "development": "./src/render.ts",
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc",
    "test:node": "node ./bin/fieldtest.js"
  },
  "dependencies": {
    "fieldtest": "workspace:*",
    "glob": "^13.0.6",
    "happy-dom": "^20.9.0",
    "tsx": "^4.21.0",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
