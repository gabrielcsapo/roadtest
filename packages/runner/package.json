{
  "name": "@roadtest/runner",
  "version": "0.0.1",
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    "./bin/roadtest.js": "./bin/roadtest.js",
    "./render": {
      "development": "./src/render.ts",
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc",
    "test:node": "node ./bin/roadtest.js"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "happy-dom": "^20.9.0",
    "roadtest": "workspace:*",
    "tsx": "^4.21.0",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
